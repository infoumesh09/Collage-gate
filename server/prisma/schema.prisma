generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  moodle_id             String                @id
  name                  String
  role                  String
  face_template         String?
  vehicle_plate         String?
  status                String                @default("active")
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  photo                 String?
  department            String?
  division              String?
  profile_photo         String?
  roll_number           String?
  year                  String?
  access_logs           AccessLog[]
  attendance_logs       Attendance[]
  presence              Presence[]
  vehicle_registrations VehicleRegistration[]

  @@map("users")
}

model AccessLog {
  id             String   @id @default(cuid())
  moodle_id      String
  method         String
  direction      String
  success        Boolean
  confidence     Float?
  plate_detected String?
  note           String?
  timestamp      DateTime @default(now())
  user           User     @relation(fields: [moodle_id], references: [moodle_id])

  @@map("access_logs")
}

model Setting {
  id             Int      @id @default(autoincrement())
  face_threshold Float    @default(0.6)
  allow_manual   Boolean  @default(true)
  max_retries    Int      @default(3)
  updated_at     DateTime @updatedAt

  @@map("settings")
}

model VehicleRegistration {
  id         String   @id @default(cuid())
  moodle_id  String
  plate      String
  status     String   @default("pending")
  note       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [moodle_id], references: [moodle_id])

  @@map("vehicle_registrations")
}

model Presence {
  id             String    @id @default(cuid())
  moodle_id      String
  type           String
  plate          String?
  last_direction String
  entered_at     DateTime
  exited_at      DateTime?
  status         String    @default("inside")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  user           User      @relation(fields: [moodle_id], references: [moodle_id])

  @@map("presence")
}

model StudentRegistration {
  id              String   @id @default(cuid())
  moodle_id       String
  name            String
  email           String?
  status          String   @default("pending")
  note            String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  face_descriptor String?
  photo           String?
  division        String?
  year            String?

  @@map("student_registrations")
}

model DailyStat {
  id             String   @id @default(cuid())
  date           DateTime @unique
  entries        Int      @default(0)
  exits          Int      @default(0)
  denied         Int      @default(0)
  total_attempts Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("daily_stats")
}

model Attendance {
  id         String    @id @default(cuid())
  moodle_id  String
  date       DateTime
  year       String?
  division   String?
  entry_time DateTime?
  exit_time  DateTime?
  status     String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  user       User      @relation(fields: [moodle_id], references: [moodle_id])

  @@unique([moodle_id, date])
  @@map("attendance_logs")
}
